<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="18dp"
    app:cardCornerRadius="22dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TOP ROW -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/inventoryMedicineName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#2F855A"
                android:textSize="24sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/inventoryPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#1A202C"
                android:textSize="24sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- CATEGORY -->

        <TextView
            android:id="@+id/inventoryCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#5B665E"
            android:textSize="16sp"
            android:layout_marginTop="10dp"/>

        <!-- DIVIDER -->

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E2E8F0"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"/>

        <!-- BOTTOM ROW -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/inventoryStock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#2F855A"
                android:textStyle="bold"
                android:background="#E6F4EA"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"/>

            <TextView
                android:id="@+id/inventoryExpiry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#5B665E"
                android:textSize="15sp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>