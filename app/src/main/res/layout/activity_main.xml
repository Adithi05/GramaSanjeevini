<?xml version="1.0" encoding="utf-8"?>

<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- MAIN CONTENT -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- TOP HEADER -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:background="@color/card_light">

            <!-- LEFT -->

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔗"
                    android:textSize="24sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Grama-Sanjeevini"
                    android:textColor="#2F855A"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:layout_marginStart="10dp"/>
            </LinearLayout>

            <!-- MOON -->


            <!-- MENU -->

            <ImageButton
                android:id="@+id/menuButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_menu_sort_by_size"/>
        </LinearLayout>

        <!-- FRAGMENT CONTAINER -->

        <FrameLayout
            android:id="@+id/fragment_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

    </LinearLayout>

    <!-- SIDEBAR -->
    <!-- SIDEBAR -->

    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="#FAFAF8"
        android:padding="22dp">

        <!-- TOP -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Grama-Sanjeevini"
                android:textColor="#2F855A"
                android:textStyle="bold"
                android:textSize="24sp"/>

            <ImageButton
                android:id="@+id/closeDrawer"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@android:color/transparent"
                android:padding="4dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="#2F855A"/>
        </LinearLayout>

        <!-- LINE -->

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="18dp"/>

        <!-- EMERGENCY -->

        <Button
            android:id="@+id/emergencyButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="@string/emergency"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#E53E3E"/>

        <!-- ALERTS -->

        <Button
            android:id="@+id/alertsButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Alerts"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#DD7A2D"
            android:layout_marginTop="16dp"/>





        <!-- LANGUAGE -->



        <!-- SPACE -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- DASHBOARD -->

        <Button
            android:id="@+id/dashboardButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Dashboard"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2F855A"/>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>